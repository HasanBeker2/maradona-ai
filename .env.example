# ═══════════════════════════════════════
# Maradona AI Project Assistant — .env
# ═══════════════════════════════════════

# --- PostgreSQL ---
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://maradona:changeme@localhost:5432/maradona

# --- Backend ---
PORT=3000
NODE_ENV=development

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (Whisper voice transcription) ---
OPENAI_API_KEY=sk-...

# --- Basecamp ---
BASECAMP_CLIENT_ID=
BASECAMP_CLIENT_SECRET=
BASECAMP_ACCESS_TOKEN=
BASECAMP_ACCOUNT_ID=
BASECAMP_PROJECT_ID=
BASECAMP_TODOLIST_ID=
BASECAMP_REDIRECT_URI=http://SUNUCU_IP:3000/auth/basecamp/callback

# --- Dashboard login ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password
JWT_SECRET=change-this-to-a-long-random-secret

# --- Dashboard API auth (legacy, replaced by JWT login) ---
API_SECRET=change-this-to-a-long-random-string

# --- Frontend ---
FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- WhatsApp (whatsapp-web.js) ---
# Session is persisted here (survives restarts)
WWEBJS_AUTH_PATH=.wwebjs_auth
# Leave empty on Windows/Mac (puppeteer auto-downloads Chromium)
# Set to /usr/bin/chromium inside Docker
PUPPETEER_EXECUTABLE_PATH=

# --- Privacy notice (sent to each group on first bot message) ---
# Leave empty to use the default Turkish/English notice
PRIVACY_NOTICE_TEXT=

# --- Weekly summary scheduler ---
# Cron: default = every Sunday at 20:00
SUMMARY_CRON=0 20 * * 0
TZ=Europe/Istanbul

# --- Logging ---
LOG_LEVEL=info
