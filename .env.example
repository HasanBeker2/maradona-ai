
#
# Server
PORT=3000
NODE_ENV=development

# WhatsApp Cloud API
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_api_key

# Basecamp
BASECAMP_ACCESS_TOKEN=your_basecamp_access_token
BASECAMP_ACCOUNT_ID=your_basecamp_account_id
BASECAMP_PROJECT_ID=your_basecamp_project_id
BASECAMP_TODOLIST_ID=your_basecamp_todolist_id

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/maradona

# Redis
REDIS_URL=redis://localhost:6379
